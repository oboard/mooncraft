import {
  "moonbitlang/core/json",
  "moonbitlang/async",
  "lepus-apps/lepus",
  "lepus-apps/webview",
}

options(
  "is-main": true,
  link: {
    "native": {
      "cc": "../.mooncakes/lepus-apps/lepus/_build/native/release/build/cli/cc/cc.exe",
    },
  },
  "pre-build": [
    {
      "command": ":embed -i $input -o $output --binary",
      "input": "../_build/dist.zip",
      "output": "dist.zip.mbt",
    },
  ],
)
